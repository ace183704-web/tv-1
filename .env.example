# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# FIREBASE_API_KEY: Web API Key for standard Firebase Authentication.
# Place your real Firebase Web API Key in the Secrets Panel under this key name.
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY_HERE

# FIREBASE_PROJECT_ID: The unique project ID of your Firebase app for realtime remote provisioning.
# Place your real Firebase Realtime Database project ID here.
FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID_HERE
